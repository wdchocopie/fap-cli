# Sao chép file này thành .env rồi điền. KHÔNG commit file .env.
# Copy this to .env and fill in. DO NOT commit .env.

# Ngôn ngữ thông báo/log: vi | en
FAP_LANG=vi

# Học kỳ — để trống = tự dò qua GetSemester. Ép: vd Spring2026
FAP_SEMESTER=

# Telegram (BotFather cho TOKEN; CHAT = id chat/kênh)
TELEGRAM_TOKEN=
TELEGRAM_CHAT=

# Discord (Server Settings → Integrations → Webhooks → New Webhook → Copy URL)
DISCORD_WEBHOOK_URL=

# Google Calendar (primary = lịch chính). Cần credentials.json + chạy `fap calendar-auth`
GCAL_CALENDAR_ID=primary

# --- Bot tương tác (fap telegram-bot / fap discord-bot) ---
# Telegram bot: dùng lại TELEGRAM_TOKEN + TELEGRAM_CHAT ở trên (TELEGRAM_CHAT BẮT BUỘC để khóa bot).
# Discord bot: token bot (KHÁC webhook URL) + id user của bạn để chỉ trả lời bạn.
# DISCORD_ALLOWED_USER_ID BẮT BUỘC; muốn mở bot cho mọi người thì đặt DISCORD_ALLOW_ANYONE=1.
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USER_ID=
# DISCORD_ALLOW_ANYONE=1   # (NGUY HIỂM) cho phép chạy discord-bot khi KHÔNG đặt ALLOWED_USER_ID
# Nhắc trước mỗi tiết: số PHÚT trước giờ vào lớp bot tự nhắc (mặc định 30, mỗi tiết 1 lần). 0 = tắt.
FAP_REMIND_MINUTES=

# --- Theo dõi điểm danh (fap watch-attendance) ---
# 1 = CHỈ báo buổi vắng/muộn (đỡ spam "Có mặt"). Để trống = báo mọi buổi mới.
FAP_WATCH_ABSENT_ONLY=

# --- Cache (máy yếu / lịch sự với server) ---
# Số PHÚT cache phản hồi API trong bộ nhớ (giảm gọi lại endpoint giống nhau). 0/trống = tắt.
# Hữu ích cho `fap web` (chạy nền) và `fap status`. Đặt nhỏ (vd 5) để dữ liệu không quá cũ.
FAP_CACHE_MIN=

# --- Trích xuất (fap extract) ---
# Giây nghỉ giữa mỗi lượt gọi API khi `fap extract` (lịch sự với server). Mặc định 0.7.
FAP_EXTRACT_DELAY=
